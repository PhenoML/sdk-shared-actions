{
  "openapi": "3.0.3",
  "info": { "title": "Fixture API", "version": "fixture-abc123" },
  "paths": {
    "/agent/create": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/agent_AgentCreateRequest" },
              "example": {
                "name": "Medical Assistant",
                "description": "Helps with FHIR coding",
                "role": "assistant"
              }
            }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/agent_AgentResponse" },
                "example": { "id": "agent_123", "name": "Medical Assistant" }
              }
            }
          }
        }
      }
    },
    "/agent/{id}": {
      "get": {
        "parameters": [ { "$ref": "#/components/parameters/agent_IdParam" } ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": { "id": "agent_123", "name": "Medical Assistant" }
              }
            }
          }
        }
      },
      "delete": {
        "parameters": [ { "$ref": "#/components/parameters/agent_IdParam" } ],
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/agent/list": {
      "get": {
        "parameters": [
          { "name": "tags", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": { "agents": [ { "id": "agent_123" } ] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent/stream": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "prompt": { "type": "string" } } },
              "example": { "prompt": "hello" }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "example": { "delta": "..." }
              }
            }
          }
        }
      }
    },
    "/agent/dual-content": {
      "post": {
        "responses": {
          "200": {
            "description": "Streaming endpoint with a placeholder JSON content type alongside SSE.",
            "content": {
              "application/json": {
                "example": { "delta": "..." }
              },
              "text/event-stream": {
                "example": { "delta": "..." }
              }
            }
          }
        }
      }
    },
    "/agent/union": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "oneOf": [
                  { "$ref": "#/components/schemas/agent_AgentRole" },
                  { "$ref": "#/components/schemas/fhir_provider_Provider" }
                ]
              },
              "example": "assistant"
            }
          }
        },
        "responses": {
          "200": { "content": { "application/json": { "example": { "ok": true } } } }
        }
      }
    },
    "/agent/{id}/comments/{comment_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/agent_IdParam" },
        { "name": "comment_id", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "verbose", "in": "query", "schema": { "type": "boolean" } }
      ],
      "get": {
        "responses": { "200": { "content": { "application/json": { "example": { "id": "c1" } } } } }
      },
      "patch": {
        "parameters": [
          { "name": "verbose", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "204": { "description": "No content" } }
      }
    }
  },
  "components": {
    "parameters": {
      "agent_IdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "agent_AgentCreateRequest": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "role": { "$ref": "#/components/schemas/agent_AgentRole" },
          "provider": { "$ref": "#/components/schemas/fhir_provider_Provider" },
          "tag": { "$ref": "#/components/schemas/agent_Tag" }
        }
      },
      "agent_AgentRole": {
        "type": "string",
        "enum": ["assistant", "user", "system"]
      },
      "fhir_provider_Provider": {
        "type": "string",
        "enum": ["epic", "google_healthcare"]
      },
      "agent_Tag": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "color": { "type": "string" }
        }
      },
      "agent_AgentResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
